generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model achievment {
  id             Int      @id @default(autoincrement())
  module_id      Int
  user_id        Int
  level          String
  score          Int
  success        Boolean  @default(false)
  date           DateTime
  total_duration Int
  module         module   @relation(fields: [module_id], references: [id], map: "Achievment_module_id_fkey")
  user           user     @relation(fields: [user_id], references: [id], map: "Achievment_user_id_fkey")

  @@index([module_id], map: "Achievment_module_id_fkey")
  @@index([user_id], map: "Achievment_user_id_fkey")
}

model answer {
  id            Int      @id @default(autoincrement())
  question_id   Int
  title_answer  String
  result_answer Boolean  @default(false)
  question      question @relation(fields: [question_id], references: [id], map: "Answer_question_id_fkey")

  @@index([question_id], map: "Answer_question_id_fkey")
}

model module {
  id           Int          @id @default(autoincrement())
  module_title String       @unique(map: "Module_module_title_key")
  achievment   achievment[]
  question     question[]
}

model question {
  id                Int      @id @default(autoincrement())
  module_id         Int
  question_title    String
  question_level    String
  question_duration Int
  answer            answer[]
  module            module   @relation(fields: [module_id], references: [id], map: "Question_module_id_fkey")

  @@index([module_id], map: "Question_module_id_fkey")
}

model quizsession {
  id             Int       @id @default(autoincrement())
  user_id        Int
  questionIds    String    @db.LongText
  wrongAnswerIds String?   @db.LongText
  score          Int
  totalQuestions Int       @default(50)
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  user           user      @relation(fields: [user_id], references: [id], map: "QuizSession_user_id_fkey")

  @@index([user_id], map: "QuizSession_user_id_fkey")
}

model user {
  id          Int           @id @default(autoincrement())
  email       String        @unique(map: "User_email_key")
  firstname   String
  lastname    String
  password    String
  achievment  achievment[]
  quizsession quizsession[]
}
